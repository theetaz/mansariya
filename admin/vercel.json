{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://mansariya-api.nipuntheekshana.com/api/:path*"
    },
    {
      "source": "/ws/:path*",
      "destination": "https://mansariya-api.nipuntheekshana.com/ws/:path*"
    },
    {
      "source": "/health",
      "destination": "https://mansariya-api.nipuntheekshana.com/health"
    },
    {
      "source": "/docs/:path*",
      "destination": "https://mansariya-api.nipuntheekshana.com/docs/:path*"
    },
    {
      "source": "/nominatim/:path*",
      "destination": "https://nominatim.openstreetmap.org/:path*"
    },
    {
      "source": "/osrm/:path*",
      "destination": "https://router.project-osrm.org/:path*"
    },
    {
      "source": "/((?!api|ws|health|docs|nominatim|osrm|assets).*)",
      "destination": "/index.html"
    }
  ]
}
