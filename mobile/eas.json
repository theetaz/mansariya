{
  "cli": {
    "version": ">= 15.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "API_URL_IOS": "https://mansariya-api.nipuntheekshana.com",
        "API_URL_ANDROID": "https://mansariya-api.nipuntheekshana.com",
        "API_URL_PROD": "https://mansariya-api.nipuntheekshana.com",
        "MAP_STYLE_URL": "https://tiles.openfreemap.org/styles/liberty"
      },
      "ios": {
        "simulator": false
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "env": {
        "API_URL_IOS": "https://mansariya-api.nipuntheekshana.com",
        "API_URL_ANDROID": "https://mansariya-api.nipuntheekshana.com",
        "API_URL_PROD": "https://mansariya-api.nipuntheekshana.com",
        "MAP_STYLE_URL": "https://tiles.openfreemap.org/styles/liberty"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
