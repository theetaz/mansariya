{
  "name": "mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "local": "cp .env.local .env && expo start --clear",
    "local:ios": "cp .env.local .env && expo run:ios",
    "local:android": "cp .env.local .env && expo run:android",
    "prod": "cp .env.production .env && expo start --clear",
    "prod:ios": "cp .env.production .env && expo run:ios",
    "prod:android": "cp .env.production .env && expo run:android"
  },
  "dependencies": {
    "@maplibre/maplibre-react-native": "^10.4.2",
    "@noble/hashes": "^2.0.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.10",
    "axios": "^1.14.0",
    "babel-preset-expo": "^55.0.13",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-localization": "~17.0.8",
    "expo-location": "~19.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-task-manager": "~14.0.9",
    "i18next": "^26.0.2",
    "react": "19.1.0",
    "react-i18next": "^17.0.1",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "nativewind": "^4.2.3",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.2"
  },
  "private": true
}
